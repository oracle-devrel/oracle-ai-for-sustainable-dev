DB_URL=jdbc:oracle:thin:@//localhost:1521/FREEPDB1
DB_USERNAME=lakehouse_demo
DB_PASSWORD=change-me

# Set this to the Oracle SQL object that exposes an Iceberg-backed table.
# Examples: LAKEHOUSE_DEMO.SALES_ICEBERG, ICEBERG_SALES, EXT_ICEBERG_ORDERS
ICEBERG_TABLE_NAME=LAKEHOUSE_DEMO.SALES_ICEBERG
ICEBERG_SAMPLE_LIMIT=25
ICEBERG_QUERY_TIMEOUT_SECONDS=30
ORACLE_JDBC_ROW_PREFETCH=100
