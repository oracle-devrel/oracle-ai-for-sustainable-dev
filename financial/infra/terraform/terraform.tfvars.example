# Uses ~/.oci/config by default. Set config_file_profile to the profile you want
# Terraform to use.
auth                = "APIKey"
config_file_profile = "DEFAULT"
region              = "eu-frankfurt-1"
home_region         = null

# Leave these null when using config_file_profile. Set them only when you do not
# want Terraform to read ~/.oci/config.
tenancy_ocid     = null
user_ocid        = null
fingerprint      = null
private_key_path = null

compartment_ocid   = "ocid1.compartment.oc1..replace"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

create_cluster          = true
oke_cluster_name        = "financial-demo"
kubernetes_version      = "v1.36.0"
worker_pool_size        = 2
worker_shape = {
  shape                   = "VM.Standard.E4.Flex"
  ocpus                   = 2
  memory                  = 16
  boot_volume_size        = 50
  boot_volume_vpus_per_gb = 10
}
create_bastion                    = false
create_operator                   = false
control_plane_is_public           = true
assign_public_ip_to_control_plane = true
control_plane_allowed_cidrs       = ["203.0.113.10/32"]
cni_type                          = "npn"
vcn_cidrs                         = ["10.0.0.0/16"]
pods_cidr                         = "10.244.0.0/16"
services_cidr                     = "10.96.0.0/16"
output_detail                     = true
enable_cert_manager               = true
enable_native_ingress_controller  = false
create_native_ingress_controller_policy = false

# Set create_database=false when using an existing Autonomous Database.
create_database                  = false
existing_autonomous_database_ocid = "ocid1.autonomousdatabase.oc1.eu-frankfurt-1..replace"

# Only used when create_database=true.
autonomous_database_name           = "financialdb"
autonomous_database_display_name   = "financialdb"
autonomous_database_admin_password = "ReplaceWithAStrongPassword123"
autonomous_database_workload       = "OLTP"
autonomous_database_version        = "26ai"
autonomous_database_compute_model  = "ECPU"
autonomous_database_compute_count  = 2
autonomous_database_storage_tbs    = 1
autonomous_database_mtls_required  = true
autonomous_database_auto_scaling   = true

freeform_tags = {
  app = "financial-demo"
}

oke_freeform_tags = {
  bastion           = { app = "financial-demo" }
  cluster           = { app = "financial-demo" }
  iam               = { app = "financial-demo" }
  network           = { app = "financial-demo" }
  operator          = { app = "financial-demo" }
  persistent_volume = { app = "financial-demo" }
  service_lb        = { app = "financial-demo" }
  workers           = { app = "financial-demo" }
}
