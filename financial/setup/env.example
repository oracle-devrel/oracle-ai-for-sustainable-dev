# Copy this file to financial/setup/.env and fill in your values.

# OCI and image registry
OCI_REGION=eu-frankfurt-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..replace
DOCKER_REGISTRY=fra.ocir.io/<tenancy-namespace>/financial
TAG=dev
CONTAINER_CLI=podman
OCIR_REGISTRY=fra.ocir.io
OCIR_TENANCY_NAMESPACE=<tenancy-namespace>
OCIR_IDENTITY_DOMAIN=<identity-domain-name>
OCI_USERNAME=<your-oci-username-or-email>
OCIR_USERNAME=<tenancy-namespace>/<domain-name>/<your-oci-username-or-email>
OCIR_AUTH_TOKEN=<oci-auth-token>
OCIR_PULL_SECRET_NAME=ocir-pull-secret

# Cluster and Kubernetes
OKE_CLUSTER_OCID=ocid1.cluster.oc1.<region>.replace
OKE_NODEPOOL_OCID=ocid1.nodepool.oc1.<region>.replace
KUBE_API_ENDPOINT=<kubernetes-api-host>:6443
K8S_NAMESPACE=financial
PUBLIC_HOSTNAME=oracledev.ai
APP_BASE_PATH=/financial
API_BASE_PATH=/financial/api
ACCOUNTS_API_BASE_PATH=/financial/accounts-api
TRANSFER_API_BASE_PATH=/financial/transfer-api
MERN_BACKEND_BASE_PATH=/financial/mern-backend
PUBLIC_BASE_URL=https://oracledev.ai/financial
INGRESS_CLASS_NAME=nginx
INGRESS_EXTERNAL_IP=<nginx-ingress-load-balancer-ip>

# Optional nginx ingress Basic Auth for the public financial app.
# The password belongs only in setup/.env, never in git.
INGRESS_BASIC_AUTH_ENABLED=false
INGRESS_BASIC_AUTH_SECRET_NAME=financial-basic-auth
INGRESS_BASIC_AUTH_REALM=Financial
INGRESS_BASIC_AUTH_USERNAME=financial
INGRESS_BASIC_AUTH_PASSWORD=replace-with-webapp-password

# Database
EXISTING_AUTONOMOUS_DATABASE_OCID=ocid1.autonomousdatabase.oc1.<region>.replace
DB_SERVICE=financialdb_high
DB_USER=financial
DB_PASSWORD=replace-with-app-user-password
DB_URL=jdbc:oracle:thin:@financialdb_high?TNS_ADMIN=/oraclefinancial/creds
WALLET_DIR=/path/to/Wallet_financialdb

# Database setup runner. Use SQLcl (`sql`) or SQL*Plus (`sqlplus`).
SETUP_DATABASE=false
DB_ADMIN_CONNECT=admin/password@financialdb_high
APP_DB_CONNECT=financial/password@financialdb_high
RUN_GRAPH_SETUP=true
RUN_KAFKA_SETUP=true
RUN_MONGO_JSON_DUALITY_SETUP=false
RUN_ORDS_SETUP=true
RUN_TRUECACHE_SETUP=true

# Optional MicroTx. The app assumes this service DNS by default.
DEPLOY_MICROTX=true
OTMM_COORDINATOR_URL=http://otmm-tcs.otmm:9000/api/v1/lra-coordinator

# Frontend build-time API URLs. These are used by Create React App.
PUBLIC_URL=/financial
REACT_APP_BASE_PATH=/financial
REACT_APP_API_BASE_PATH=/financial/api
REACT_APP_MICROTX_ACCOUNT_SERVICE_URL=/financial/accounts-api
REACT_APP_MICROTX_TRANSFER_SERVICE_URL=/financial/transfer-api
REACT_APP_MERN_SQL_ORACLE_SERVICE_URL=/financial/accounts-api
REACT_APP_MERN_MONGODB_JSONDUALITY_ORACLE_SERVICE_URL=/financial/mern-backend
REACT_APP_MERN_BACKEND_SERVICE_URL=/financial/mern-backend
REACT_APP_MERN_MONGODB_SERVICE_URL=/financial/accounts-api
REACT_APP_AI_AGENTS_BACKEND_URL=/financial/aiagent
REACT_APP_GRAFANA_URL=/financial/grafana
REACT_APP_ORDS_BASE_URL=https://replace-adb-host/ords

# Optional image name overrides
REACT_FRONTEND_IMAGE_NAME=react-frontend
SPRINGBOOT_BACKEND_IMAGE_NAME=springboot-backend
MICROTX_ACCOUNT_IMAGE_NAME=microtx-account
MICROTX_TRANSFER_IMAGE_NAME=microtx-transfer
