
# Database Configuration for Spring Boot Services
export SPRING_DATASOURCE_URL=jdbc:oracle:thin:@financialdb_high?TNS_ADMIN=/path/to/Wallet_financialdb
export SPRING_DATASOURCE_USERNAME=<database-user>
export SPRING_DATASOURCE_PASSWORD=<database-password>

# MongoDB Configuration for MERN Stack (Oracle JSON Duality View)
export MONGO_URI="mongodb://<database-user>:<database-password>@<adb-mongodb-api-host>:27017/<database-name>?authMechanism=PLAIN&authSource=\$external&ssl=true&retryWrites=false&loadBalanced=true"

# Application Configuration
export REACT_APP_MERN_SQL_ORACLE_SERVICE_URL=http://localhost:8080
export REACT_APP_MERN_MONGODB_JSONDUALITY_ORACLE_SERVICE_URL=http://localhost:5001
export REACT_APP_MERN_MONGODB_SERVICE_URL=http://localhost:8080

export REACT_APP_MICROTX_TRANSFER_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_MICROTX_ACCOUNT_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_JAVA_ACCOUNTDETAIL_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_GRAPH_LAUNDERING_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_TRUECACHE_STOCK_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_SHARDING_SPATIAL_CC_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_STOCK_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_KAFKA_TXEVENTQ_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_AIAGENT_VECTOR_ADVISOR_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_SPEECH_SELECTAI_QUERY_SERVICE_URL=http://localhost:8080/accounts
export REACT_APP_AI_AGENTS_BACKEND_URL=http://localhost:8080
export REACT_APP_ORDS_BASE_URL=https://asdf-financialdb.adb.eu-frankfurt-1.oraclecloudapps.com/ords

# Optional nginx ingress Basic Auth for deployed /financial access.
# Put real values only in ignored .env/setup .env files.
export INGRESS_BASIC_AUTH_ENABLED=false
export INGRESS_BASIC_AUTH_SECRET_NAME=financial-basic-auth
export INGRESS_BASIC_AUTH_REALM=Financial
export INGRESS_BASIC_AUTH_USERNAME=financial
export INGRESS_BASIC_AUTH_PASSWORD=<webapp-password>

# Display all set environment variables
echo "=== Environment Variables Set ==="
echo "REACT_APP_MERN_MONGODB_SERVICE_URL: $REACT_APP_MERN_MONGODB_SERVICE_URL"
echo "REACT_APP_MERN_MONGODB_JSONDUALITY_ORACLE_SERVICE_URL: $REACT_APP_MERN_MONGODB_JSONDUALITY_ORACLE_SERVICE_URL"
echo "REACT_APP_MERN_SQL_ORACLE_SERVICE_URL: $REACT_APP_MERN_SQL_ORACLE_SERVICE_URL"
echo "REACT_APP_MICROTX_TRANSFER_SERVICE_URL: $REACT_APP_MICROTX_TRANSFER_SERVICE_URL"
echo "REACT_APP_MICROTX_ACCOUNT_SERVICE_URL: $REACT_APP_MICROTX_ACCOUNT_SERVICE_URL"
echo "REACT_APP_JAVA_ACCOUNTDETAIL_SERVICE_URL: $REACT_APP_JAVA_ACCOUNTDETAIL_SERVICE_URL"
echo "REACT_APP_GRAPH_LAUNDERING_SERVICE_URL: $REACT_APP_GRAPH_LAUNDERING_SERVICE_URL"
echo "REACT_APP_TRUECACHE_STOCK_SERVICE_URL: $REACT_APP_TRUECACHE_STOCK_SERVICE_URL"
echo "REACT_APP_SHARDING_SPATIAL_CC_SERVICE_URL: $REACT_APP_SHARDING_SPATIAL_CC_SERVICE_URL"
echo "REACT_APP_STOCK_SERVICE_URL: $REACT_APP_STOCK_SERVICE_URL"
echo "REACT_APP_KAFKA_TXEVENTQ_SERVICE_URL: $REACT_APP_KAFKA_TXEVENTQ_SERVICE_URL"
echo "REACT_APP_AIAGENT_VECTOR_ADVISOR_SERVICE_URL: $REACT_APP_AIAGENT_VECTOR_ADVISOR_SERVICE_URL"
echo "REACT_APP_SPEECH_SELECTAI_QUERY_SERVICE_URL: $REACT_APP_SPEECH_SELECTAI_QUERY_SERVICE_URL"
echo "REACT_APP_AI_AGENTS_BACKEND_URL: $REACT_APP_AI_AGENTS_BACKEND_URL"
echo "REACT_APP_ORDS_BASE_URL: $REACT_APP_ORDS_BASE_URL"
echo "SPRING_DATASOURCE_URL: $SPRING_DATASOURCE_URL"
echo "SPRING_DATASOURCE_USERNAME: $SPRING_DATASOURCE_USERNAME"
echo "SPRING_DATASOURCE_PASSWORD: <set>"
echo "MONGO_URI: <set>"
echo "=== All environment variables have been set successfully! ==="
