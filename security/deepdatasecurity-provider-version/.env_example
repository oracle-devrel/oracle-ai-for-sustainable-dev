TNS_ADMIN="/path/to/Wallet_aiholodb"
DEEPSEC_JDBC_URL="jdbc:oracle:thin:@mydb_high_app?TNS_ADMIN=${TNS_ADMIN}"
DEEPSEC_USERNAME="admin"
DEEPSEC_PASSWORD="your_database_password"
DEEPSEC_POOL_SIZE="4"
SPRING_PROFILES_ACTIVE="entraid"
# Optional UCP overrides:
# DEEPSEC_UCP_POOL_NAME="DeepDataSecurityProviderUcpPool"
# DEEPSEC_UCP_INITIAL_POOL_SIZE="1"
# DEEPSEC_UCP_MIN_POOL_SIZE="1"

# Optional demo query override.
DEEPSEC_SQL="select employee_id || ':' || first_name || ' ' || last_name from hr.employees fetch first 10 rows only"

# Microsoft Entra ID OAuth configuration.
# DEEPSEC_ENTRA_JWT_ISSUER_URI must match the iss claim in the incoming access token.
DEEPSEC_ENTRA_TENANT_ID="your-tenant-id"
DEEPSEC_ENTRA_JWT_ISSUER_URI="https://login.microsoftonline.com/your-tenant-id/v2.0"
DEEPSEC_ENTRA_CLIENT_ID="your_spring_boot_client_app_id"
DEEPSEC_ENTRA_CLIENT_SECRET="your_spring_boot_client_secret_value"
DEEPSEC_ENTRA_DATABASE_SCOPE="api://your_database_app_client_id/.default"
# Database-access token flow. client_credentials is the simplest service assertion.
# Use urn:ietf:params:oauth:grant-type:jwt-bearer only with an IAM registration
# configured for the on-behalf-of flow.
DEEPSEC_ENTRA_DATABASE_GRANT_TYPE="client_credentials"
DEEPSEC_ENTRA_APPLICATION_SCOPE="api://your_spring_boot_client_app_id/user_impersonation"
# Optional override when the token issuer is not one of the default Entra v1/v2 issuer URLs.
# Comma-separated list.
# DEEPSEC_ENTRA_JWT_TRUSTED_ISSUERS="https://sts.windows.net/your-tenant-id/,https://login.microsoftonline.com/your-tenant-id/v2.0"

# Optional: use a separate public-client app registration for the browser UI.
# Configure it in Entra as a SPA with redirect URI http://localhost:18080.
DEEPSEC_ENTRA_BROWSER_CLIENT_ID="${DEEPSEC_ENTRA_CLIENT_ID}"
