TNS_ADMIN="/path/to/Wallet_aiholodb"
DEEPSEC_JDBC_URL="jdbc:oracle:thin:@mydb_high_app?TNS_ADMIN=${TNS_ADMIN}"
DEEPSEC_USERNAME="admin"
DEEPSEC_PASSWORD="your_database_password"
DEEPSEC_POOL_SIZE="4"
SPRING_PROFILES_ACTIVE="oci-iam"

# Optional demo query override.
DEEPSEC_SQL="select employee_id || ':' || first_name || ' ' || last_name from hr.employees fetch first 10 rows only"

# OCI IAM / Identity Domain OAuth configuration.
# DEEPSEC_OCI_IAM_DOMAIN_URL is the base URL for the identity domain, for example:
# https://idcs-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa.identity.oraclecloud.com
DEEPSEC_OCI_IAM_DOMAIN_URL="https://your-identity-domain.identity.oraclecloud.com"
DEEPSEC_OCI_IAM_CLIENT_ID="your_oci_iam_confidential_app_client_id"
DEEPSEC_OCI_IAM_CLIENT_SECRET="your_oci_iam_confidential_app_client_secret"
DEEPSEC_OCI_IAM_DATABASE_SCOPE="your_database_scope_or_resource/.default"

# Override these if your identity-domain metadata or LiveLabs setup uses a
# different issuer/token endpoint. DEEPSEC_OCI_IAM_JWT_TRUSTED_ISSUERS is
# comma-separated.
# DEEPSEC_OCI_IAM_AUTHORIZATION_URI="${DEEPSEC_OCI_IAM_DOMAIN_URL}/oauth2/v1/authorize"
# DEEPSEC_OCI_IAM_TOKEN_URI="${DEEPSEC_OCI_IAM_DOMAIN_URL}/oauth2/v1/token"
# DEEPSEC_OCI_IAM_ISSUER_URI="${DEEPSEC_OCI_IAM_DOMAIN_URL}"
# DEEPSEC_OCI_IAM_JWT_TRUSTED_ISSUERS="${DEEPSEC_OCI_IAM_ISSUER_URI}"

# Browser UI is currently Entra/MSAL-only. For OCI IAM, call protected endpoints
# with Authorization: Bearer <OCI_IAM_ACCESS_TOKEN>.
DEEPSEC_BROWSER_ENABLED="false"
